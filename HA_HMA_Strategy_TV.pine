// ============================================================================
//  HA + HMA Strategy v5 — JP
//  TradingView Pine Script v5
//  Instrument : ETHUSDT.P
//  Timeframe  : 10M–15M recommandé
//
//  SHORT : Classic rouge + HA rouge + HA Close < HMA(50)
//          SL = High bougie HA
//          TP = HA vert + HA Close > HMA(20) → close candle classique
//          Breakeven : quand gain = distance SL initiale → SL remonte à l'entrée
//
//  LONG  : Classic verte + Classic Close > HMA(50)
//          SL = Low bougie classique
//          TP = HA rouge + HA Close < HMA(20) → close candle classique
//          Breakeven : quand gain = distance SL initiale → SL remonte à l'entrée
//
//  HMA50 = filtre d'ouverture (tendance long terme)
//  HMA20 = signal de sortie (anticipation retournement court terme)
//
//  Capital : $50 000 | Risque : 2% par trade (compounding)
//  Une seule position à la fois
// ============================================================================

//@version=5
strategy(
     title                   = "HA + HMA Strategy v5 — JP",
     overlay                 = true,
     initial_capital         = 50000,
     currency                = currency.USD,
     pyramiding              = 0,
     process_orders_on_close = true,
     calc_on_every_tick      = false,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.05,
     slippage                = 1
     )

// ─────────────────────────────────────────────────────────────────────────────
//  PARAMÈTRES
// ─────────────────────────────────────────────────────────────────────────────

hmaSlowLen = input.int  (50,  "HMA Lente — période (ouverture)",  minval=5, group="HMA")
hmaFastLen = input.int  (20,  "HMA Rapide — période (sortie)",   minval=2, group="HMA")
riskPct    = input.float(2.0, "Risque par trade (%)", step=0.1, minval=0.1, maxval=10, group="Capital")

// ─────────────────────────────────────────────────────────────────────────────
//  HEIKIN ASHI (calcul manuel)
// ─────────────────────────────────────────────────────────────────────────────

haClose = (open + high + low + close) / 4.0
var float haOpenV = na
haOpenV := na(haOpenV[1]) ? (open + close) / 2.0 : (haOpenV[1] + haClose[1]) / 2.0
haHigh  = math.max(high, math.max(haOpenV, haClose))
haLow   = math.min(low,  math.min(haOpenV, haClose))

haIsRed   = haClose  < haOpenV
haIsGreen = haClose >= haOpenV

// ─────────────────────────────────────────────────────────────────────────────
//  HMA
//  hmaOnHA_slow : HMA(50) sur HA — filtre ouverture SHORT
//  hmaOnCL_slow : HMA(50) sur close classique — filtre ouverture LONG
//  hmaOnHA_fast : HMA(20) sur HA — déclencheur de sortie (les deux sens)
// ─────────────────────────────────────────────────────────────────────────────

hmaOnHA_slow = ta.hma(haClose, hmaSlowLen)
hmaOnCL_slow = ta.hma(close,   hmaSlowLen)
hmaOnHA_fast = ta.hma(haClose, hmaFastLen)

// ─────────────────────────────────────────────────────────────────────────────
//  COULEURS CLASSIQUES
// ─────────────────────────────────────────────────────────────────────────────

classicRed   = close < open
classicGreen = close > open

// ─────────────────────────────────────────────────────────────────────────────
//  SIGNAUX D'ENTRÉE
// ─────────────────────────────────────────────────────────────────────────────

isShort = strategy.position_size < 0
isLong  = strategy.position_size > 0

// SHORT : Classic rouge + HA rouge + HA Close < HMA(50)
// Entrée si pas de SHORT ouvert (retournement LONG→SHORT autorisé)
shortEntry = classicRed   and haIsRed   and haClose < hmaOnHA_slow and not isShort

// LONG : Classic verte + HA verte + HA Close > HMA(50)
// Entrée si pas de LONG ouvert (retournement SHORT→LONG autorisé)
longEntry  = classicGreen and haIsGreen and haClose > hmaOnHA_slow and not isLong

// ─────────────────────────────────────────────────────────────────────────────
//  SIGNAUX DE SORTIE — close sur candle classique
//
//  SHORT : HA VIRE AU VERT (premier bar vert après une série rouge)
//          → sortie immédiate sans attendre HMA20
//
//  LONG  : HA VIRE AU ROUGE (premier bar rouge après une série verte)
//          ET HA Close < HMA(20) → confirmation du retournement baissier
//
//  Note : pour le SHORT, on sort dès le changement de couleur HA
//         car en bas de tendance le HA vert précède toujours le passage de HMA20
// ─────────────────────────────────────────────────────────────────────────────

// EXIT SHORT : HA change de couleur (rouge→vert) ET HA Close > HMA(20)
// → fermeture sur close candle classique
exitShort = haIsGreen and haIsRed[1] and haClose > hmaOnHA_fast and strategy.position_size < 0

// EXIT LONG : HA change de couleur (vert→rouge) ET HA Close < HMA(20)
// → fermeture sur close candle classique
exitLong  = haIsRed and haIsGreen[1] and haClose < hmaOnHA_fast and strategy.position_size > 0

// ─────────────────────────────────────────────────────────────────────────────
//  GESTION DU STOP LOSS + BREAKEVEN
//  Évaluation sur close de bougie (pas intrabar)
//  Breakeven : quand gain ≥ distance SL initiale → SL remonte au prix d'entrée
// ─────────────────────────────────────────────────────────────────────────────

var float shortSL        = na
var float longSL         = na
var float shortEntry_px  = na   // Prix d'entrée mémorisé pour le breakeven
var float longEntry_px   = na
var float shortSL_init   = na   // Distance SL initiale
var float longSL_init    = na
var bool  shortBE        = false // Breakeven déjà activé ?
var bool  longBE         = false

// ── Breakeven SHORT ───────────────────────────────────────────────────────────
// Condition : close est descendu d'au moins (SL distance) sous l'entrée
if strategy.position_size < 0 and not shortBE and not na(shortSL) and not na(shortEntry_px)
    if close <= shortEntry_px - shortSL_init
        shortSL := shortEntry_px   // SL remonte au prix d'entrée
        shortBE := true

// ── Breakeven LONG ────────────────────────────────────────────────────────────
// Condition : close est monté d'au moins (SL distance) au-dessus de l'entrée
if strategy.position_size > 0 and not longBE and not na(longSL) and not na(longEntry_px)
    if close >= longEntry_px + longSL_init
        longSL := longEntry_px     // SL descend au prix d'entrée
        longBE := true

// ── SL touché ? ───────────────────────────────────────────────────────────────
slHitShort = strategy.position_size < 0 and not na(shortSL) and high >= shortSL
slHitLong  = strategy.position_size > 0 and not na(longSL)  and low  <= longSL

// ─────────────────────────────────────────────────────────────────────────────
//  CALCUL QUANTITÉ (2% risk compounding)
// ─────────────────────────────────────────────────────────────────────────────

calcQty(slDist) =>
    riskAmount = strategy.equity * riskPct / 100.0
    slDist > 0 ? riskAmount / slDist : na

// ─────────────────────────────────────────────────────────────────────────────
//  EXÉCUTION — sorties avant entrées
// ─────────────────────────────────────────────────────────────────────────────

// ── Sorties TP ────────────────────────────────────────────────────────────────
if exitShort
    strategy.close("Short", comment="TP ✓")
    shortSL := na
    shortBE := false

if exitLong
    strategy.close("Long", comment="TP ✓")
    longSL := na
    longBE := false

// ── Sorties SL ────────────────────────────────────────────────────────────────
if slHitShort
    beLabel = shortBE ? "BE ✗" : "SL ✗"
    strategy.close("Short", comment=beLabel)
    shortSL := na
    shortBE := false

if slHitLong
    beLabel = longBE ? "BE ✗" : "SL ✗"
    strategy.close("Long", comment=beLabel)
    longSL := na
    longBE := false

// ── Entrées ───────────────────────────────────────────────────────────────────
if shortEntry
    // Retournement : fermer le LONG si ouvert
    if isLong
        strategy.close("Long", comment="↕ →Short")
        longSL := na
        longBE := false
    sl_dist = haHigh - close
    qty     = calcQty(sl_dist)
    if not na(qty) and qty > 0.0
        strategy.entry("Short", strategy.short, qty=qty)
        shortSL       := haHigh
        shortEntry_px := close
        shortSL_init  := sl_dist
        shortBE       := false

if longEntry
    // Retournement : fermer le SHORT si ouvert
    if isShort
        strategy.close("Short", comment="↕ →Long")
        shortSL := na
        shortBE := false
    sl_dist = close - low
    qty     = calcQty(sl_dist)
    if not na(qty) and qty > 0.0
        strategy.entry("Long", strategy.long, qty=qty)
        longSL        := low
        longEntry_px  := close
        longSL_init   := sl_dist
        longBE        := false

// ─────────────────────────────────────────────────────────────────────────────
//  DEBUG — labels qui expliquent pourquoi un signal potentiel est bloqué
// ─────────────────────────────────────────────────────────────────────────────

debugMode = input.bool(false, "Mode debug (labels)", group="Debug")

if debugMode
    // LONG potentiel bloqué
    if classicGreen and haIsGreen
        if (isLong or isShort)
            label.new(bar_index, low, "⏸ EN POSITION", style=label.style_label_up, color=color.gray,   textcolor=color.white, size=size.tiny)
        else if not (haClose > hmaOnHA_slow)
            label.new(bar_index, low, "↑ HA<HMA50",     style=label.style_label_up, color=color.yellow, textcolor=color.black, size=size.tiny)

    // SHORT potentiel bloqué
    if classicRed and haIsRed
        if (isLong or isShort)
            label.new(bar_index, high, "⏸ EN POSITION", style=label.style_label_down, color=color.gray,   textcolor=color.white, size=size.tiny)
        else if not (haClose < hmaOnHA_slow)
            label.new(bar_index, high, "↓ HA>HMA50",     style=label.style_label_down, color=color.yellow, textcolor=color.black, size=size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
//  AFFICHAGE
// ─────────────────────────────────────────────────────────────────────────────

plot(hmaOnHA_slow, "HMA 50 (HA)",   color=color.new(color.blue,   0), linewidth=2)
plot(hmaOnHA_fast, "HMA 20 (HA)",   color=color.new(color.orange, 0), linewidth=1)

plotshape(shortEntry, "▼ Short",      shape.triangledown, location.abovebar, color.new(color.red,    0), size=size.small)
plotshape(longEntry,  "▲ Long",       shape.triangleup,   location.belowbar, color.new(color.green,  0), size=size.small)
plotshape(exitShort,  "✕ Exit Short", shape.xcross,       location.abovebar, color.new(color.orange, 0), size=size.tiny)
plotshape(exitLong,   "✕ Exit Long",  shape.xcross,       location.belowbar, color.new(color.orange, 0), size=size.tiny)

// Niveau SL (pointillé) et Breakeven (ligne pleine) visibles sur le graphique
var line slLine = na
if shortEntry
    slLine := line.new(bar_index, haHigh, bar_index + 3, haHigh, color=color.new(color.red,   50), style=line.style_dashed, width=1)
if longEntry
    slLine := line.new(bar_index, low,    bar_index + 3, low,    color=color.new(color.green, 50), style=line.style_dashed, width=1)
