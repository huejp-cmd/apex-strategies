// ============================================================================
//  HA + HMA Strategy v2 — JP
//  TradingView Pine Script v5
//  Instrument : ETHUSDT.P (ou tout perp crypto)
//  Timeframe  : 10M–15M recommandé
//
//  SHORT : Classic rouge + HA rouge + HA Close < HMA(50)
//          SL = High bougie HA | TP = HA vert + HA Close > HMA(20) → close classic
//
//  LONG  : Classic verte + Classic Close > HMA(50)  [sans filtre HA]
//          SL = Low bougie classique | TP = HA rouge + HA Close < HMA(20) → close classic
//
//  Capital : $50 000 | Risque : 2% par trade (compounding automatique)
//  Pas de filtre horaire — test 24/7
// ============================================================================

//@version=5
strategy(
     title               = "HA + HMA Strategy v2 — JP",
     overlay             = true,
     initial_capital     = 50000,
     currency            = currency.USD,
     pyramiding          = 0,
     process_orders_on_close = true,
     calc_on_every_tick  = false,
     commission_type     = strategy.commission.percent,
     commission_value    = 0.05,
     slippage            = 1
     )

// ─────────────────────────────────────────────────────────────────────────────
//  PARAMÈTRES
// ─────────────────────────────────────────────────────────────────────────────

hmaSlowLen = input.int(50,  "HMA Lente — période (filtre signal)",  minval=5,   group="HMA")
hmaFastLen = input.int(20,  "HMA Rapide — période (condition TP)",  minval=2,   group="HMA")
riskPct    = input.float(2.0, "Risque par trade (%)",               step=0.1, minval=0.1, maxval=10, group="Capital")

// ─────────────────────────────────────────────────────────────────────────────
//  HEIKIN ASHI (calcul manuel — synchronisation parfaite)
// ─────────────────────────────────────────────────────────────────────────────

haClose  = (open + high + low + close) / 4.0

var float haOpenV = na
haOpenV := na(haOpenV[1]) ? (open + close) / 2.0 : (haOpenV[1] + haClose[1]) / 2.0

haHigh = math.max(high,  math.max(haOpenV, haClose))
haLow  = math.min(low,   math.min(haOpenV, haClose))

haIsRed   = haClose < haOpenV
haIsGreen = haClose >= haOpenV

// ─────────────────────────────────────────────────────────────────────────────
//  HMA (Hull Moving Average)
//  - Sur HA Close  → filtre SHORT et conditions de sortie
//  - Sur Close classique → filtre LONG
// ─────────────────────────────────────────────────────────────────────────────

hmaSlowHA  = ta.hma(haClose, hmaSlowLen)   // HMA(50) sur HA  — signal SHORT
hmaFastHA  = ta.hma(haClose, hmaFastLen)   // HMA(20) sur HA  — sortie des deux
hmaSlowCL  = ta.hma(close,   hmaSlowLen)   // HMA(50) sur close classique — signal LONG

// ─────────────────────────────────────────────────────────────────────────────
//  COULEURS DES BOUGIES CLASSIQUES
// ─────────────────────────────────────────────────────────────────────────────

classicRed   = close < open
classicGreen = close > open

// ─────────────────────────────────────────────────────────────────────────────
//  SIGNAUX D'ENTRÉE
// ─────────────────────────────────────────────────────────────────────────────

// SHORT : Classic rouge + HA rouge + HA Close sous HMA_slow(HA)
shortEntry = classicRed and haIsRed and haClose < hmaSlowHA and strategy.position_size == 0

// LONG : Classic verte + Classic Close au-dessus HMA_slow(close) — PAS de filtre HA
longEntry  = classicGreen and close > hmaSlowCL and strategy.position_size == 0

// ─────────────────────────────────────────────────────────────────────────────
//  SIGNAUX DE SORTIE (HA donne le signal, exécution sur close classique)
// ─────────────────────────────────────────────────────────────────────────────

// Sortie SHORT : HA vert + HA Close au-dessus HMA_fast(HA)
exitShort = haIsGreen and haClose > hmaFastHA and strategy.position_size < 0

// Sortie LONG : HA rouge + HA Close sous HMA_fast(HA)
exitLong  = haIsRed and haClose < hmaFastHA and strategy.position_size > 0

// ─────────────────────────────────────────────────────────────────────────────
//  CALCUL DE LA QUANTITÉ (2% de risk — compounding)
//  Formule : Risque$ / Distance_SL = Quantité (en ETH pour ETHUSDT)
// ─────────────────────────────────────────────────────────────────────────────

calcQty(slDist) =>
    riskAmount = strategy.equity * riskPct / 100.0
    slDist > 0 ? riskAmount / slDist : na

// ─────────────────────────────────────────────────────────────────────────────
//  EXÉCUTION DES ORDRES
// ─────────────────────────────────────────────────────────────────────────────

if shortEntry
    slLevel = haHigh                        // SL = High de la bougie HA rouge
    dist    = slLevel - close
    qty     = calcQty(dist)
    if not na(qty) and qty > 0.0
        strategy.entry("Short", strategy.short, qty=qty)
        strategy.exit("SL_Short", from_entry="Short", stop=slLevel)

if longEntry
    slLevel = low                           // SL = Low de la bougie classique
    dist    = close - slLevel
    qty     = calcQty(dist)
    if not na(qty) and qty > 0.0
        strategy.entry("Long", strategy.long, qty=qty)
        strategy.exit("SL_Long", from_entry="Long", stop=slLevel)

// Sortie TP : fermeture sur close de la bougie classique quand HA donne le signal
if exitShort
    strategy.close("Short", comment="TP ✓")

if exitLong
    strategy.close("Long", comment="TP ✓")

// ─────────────────────────────────────────────────────────────────────────────
//  AFFICHAGE
// ─────────────────────────────────────────────────────────────────────────────

// HMA sur le graphique
plot(hmaSlowCL, "HMA 50 (close classique)", color=color.new(color.blue, 0),    linewidth=2)
plot(hmaFastHA, "HMA 20 (HA)",              color=color.new(color.orange, 0),  linewidth=1)
plot(hmaSlowHA, "HMA 50 (HA)",              color=color.new(color.blue, 65),   linewidth=1)

// Flèches de signal
plotshape(shortEntry, "▼ Short",     shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.small)
plotshape(longEntry,  "▲ Long",      shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.small)

// Marqueurs de sortie
plotshape(exitShort,  "✕ Exit Short", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny)
plotshape(exitLong,   "✕ Exit Long",  shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny)

// Niveau SL visible sur le graphique
var line slLine = na
if shortEntry
    slLine := line.new(bar_index, haHigh, bar_index + 3, haHigh, color=color.new(color.red, 50), style=line.style_dashed, width=1)
if longEntry
    slLine := line.new(bar_index, low,    bar_index + 3, low,    color=color.new(color.green, 50), style=line.style_dashed, width=1)
