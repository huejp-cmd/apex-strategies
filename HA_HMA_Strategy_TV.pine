// ============================================================================
//  HA + HMA Strategy v3 — JP
//  TradingView Pine Script v5
//  Instrument : ETHUSDT.P
//  Timeframe  : 10M–15M recommandé
//
//  SHORT : Classic rouge + HA rouge (×2 consécutives) + HA Close < HMA(50)
//          + HMA(50) en pente descendante + corps > X% ATR
//          SL = High bougie HA | TP = HA vert + HA Close > HMA(20)
//
//  LONG  : Classic verte + Classic Close > HMA(50)
//          + HMA(50) en pente montante + corps > X% ATR
//          SL = Low bougie classique | TP = HA rouge + HA Close < HMA(20)
//
//  Capital : $50 000 | Risque : 2% par trade (compounding)
//  UNE SEULE position à la fois
// ============================================================================

//@version=5
strategy(
     title                   = "HA + HMA Strategy v3 — JP",
     overlay                 = true,
     initial_capital         = 50000,
     currency                = currency.USD,
     pyramiding              = 0,
     process_orders_on_close = true,
     calc_on_every_tick      = false,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.05,
     slippage                = 1
     )

// ─────────────────────────────────────────────────────────────────────────────
//  PARAMÈTRES
// ─────────────────────────────────────────────────────────────────────────────

hmaSlowLen  = input.int  (50,  "HMA Lente — période",           minval=5,   group="HMA")
hmaFastLen  = input.int  (20,  "HMA Rapide — période (sortie)", minval=2,   group="HMA")
atrLen      = input.int  (14,  "ATR — période",                 minval=5,   group="Filtres")
bodyMinPct  = input.float(30.0,"Corps min (% de l'ATR)",        step=5.0, minval=5.0, maxval=100.0, group="Filtres",
                          tooltip="Bougie ignorée si son corps < X% de l'ATR. Augmenter pour moins de signaux.")
riskPct     = input.float(2.0, "Risque par trade (%)",          step=0.1, minval=0.1, maxval=10, group="Capital")

// ─────────────────────────────────────────────────────────────────────────────
//  HEIKIN ASHI (calcul manuel)
// ─────────────────────────────────────────────────────────────────────────────

haClose = (open + high + low + close) / 4.0
var float haOpenV = na
haOpenV := na(haOpenV[1]) ? (open + close) / 2.0 : (haOpenV[1] + haClose[1]) / 2.0
haHigh  = math.max(high, math.max(haOpenV, haClose))
haLow   = math.min(low,  math.min(haOpenV, haClose))

haIsRed   = haClose  < haOpenV
haIsGreen = haClose >= haOpenV

// ─────────────────────────────────────────────────────────────────────────────
//  HMA
// ─────────────────────────────────────────────────────────────────────────────

hmaSlowHA = ta.hma(haClose, hmaSlowLen)
hmaFastHA = ta.hma(haClose, hmaFastLen)
hmaSlowCL = ta.hma(close,   hmaSlowLen)

// ─────────────────────────────────────────────────────────────────────────────
//  FILTRES
// ─────────────────────────────────────────────────────────────────────────────

// Pente HMA : SHORT si HMA descend, LONG si HMA monte
hmaBearish = hmaSlowHA < hmaSlowHA[1]   // HMA(HA) en baisse  → confirme SHORT
hmaBullish = hmaSlowCL > hmaSlowCL[1]   // HMA(close) en hausse → confirme LONG

// Corps minimum basé sur ATR
atr     = ta.atr(atrLen)
bodyMin = atr * bodyMinPct / 100.0
body    = math.abs(close - open)
bodyOk  = body >= bodyMin

// Confirmation HA : 2 bougies consécutives de même couleur
haConfirmRed   = haIsRed   and haIsRed[1]    // 2 HA rouges de suite
haConfirmGreen = haIsGreen and haIsGreen[1]  // 2 HA vertes de suite

// ─────────────────────────────────────────────────────────────────────────────
//  COULEURS CLASSIQUES
// ─────────────────────────────────────────────────────────────────────────────

classicRed   = close < open
classicGreen = close > open

// ─────────────────────────────────────────────────────────────────────────────
//  SIGNAUX D'ENTRÉE
// ─────────────────────────────────────────────────────────────────────────────

noTrade = strategy.opentrades == 0

// SHORT : Classic rouge + 2 HA rouges consécutives + HA sous HMA50 + HMA descend + corps ok
shortEntry = classicRed   and haConfirmRed   and haClose < hmaSlowHA and hmaBearish and bodyOk and noTrade

// LONG : Classic verte + Classic > HMA50 + HMA monte + corps ok (sans confirmation HA)
longEntry  = classicGreen and close > hmaSlowCL               and hmaBullish and bodyOk and noTrade

// ─────────────────────────────────────────────────────────────────────────────
//  SIGNAUX DE SORTIE
// ─────────────────────────────────────────────────────────────────────────────

exitShort = haIsGreen and haClose > hmaFastHA and strategy.position_size < 0
exitLong  = haIsRed   and haClose < hmaFastHA and strategy.position_size > 0

// ─────────────────────────────────────────────────────────────────────────────
//  CALCUL QUANTITÉ (2% risk compounding)
// ─────────────────────────────────────────────────────────────────────────────

calcQty(slDist) =>
    riskAmount = strategy.equity * riskPct / 100.0
    slDist > 0 ? riskAmount / slDist : na

// ─────────────────────────────────────────────────────────────────────────────
//  EXÉCUTION — sorties avant entrées
// ─────────────────────────────────────────────────────────────────────────────

if exitShort
    strategy.close("Short", comment="TP ✓")
if exitLong
    strategy.close("Long", comment="TP ✓")

if shortEntry
    slLevel = haHigh
    dist    = slLevel - close
    qty     = calcQty(dist)
    if not na(qty) and qty > 0.0
        strategy.entry("Short", strategy.short, qty=qty)
        strategy.exit("SL_Short", from_entry="Short", stop=slLevel)

if longEntry
    slLevel = low
    dist    = close - slLevel
    qty     = calcQty(dist)
    if not na(qty) and qty > 0.0
        strategy.entry("Long", strategy.long, qty=qty)
        strategy.exit("SL_Long", from_entry="Long", stop=slLevel)

// ─────────────────────────────────────────────────────────────────────────────
//  AFFICHAGE
// ─────────────────────────────────────────────────────────────────────────────

plot(hmaSlowCL, "HMA 50 (close)", color=color.new(color.blue,   0), linewidth=2)
plot(hmaFastHA, "HMA 20 (HA)",   color=color.new(color.orange,  0), linewidth=1)
plot(hmaSlowHA, "HMA 50 (HA)",   color=color.new(color.blue,   65), linewidth=1)

plotshape(shortEntry, "▼ Short",      shape.triangledown, location.abovebar, color.new(color.red,    0), size=size.small)
plotshape(longEntry,  "▲ Long",       shape.triangleup,   location.belowbar, color.new(color.green,  0), size=size.small)
plotshape(exitShort,  "✕ Exit Short", shape.xcross,       location.abovebar, color.new(color.orange, 0), size=size.tiny)
plotshape(exitLong,   "✕ Exit Long",  shape.xcross,       location.belowbar, color.new(color.orange, 0), size=size.tiny)

var line slLine = na
if shortEntry
    slLine := line.new(bar_index, haHigh, bar_index + 3, haHigh, color=color.new(color.red,   50), style=line.style_dashed, width=1)
if longEntry
    slLine := line.new(bar_index, low,    bar_index + 3, low,    color=color.new(color.green, 50), style=line.style_dashed, width=1)
